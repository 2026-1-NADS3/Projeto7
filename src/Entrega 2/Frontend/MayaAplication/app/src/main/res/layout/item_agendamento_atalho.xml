<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/txtDataAtalho"
        android:layout_width="45dp"
        android:layout_height="wrap_content"
        android:text="02/05"
        android:textSize="11sp"
        android:textColor="#999999" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginHorizontal="8dp">

        <View
            android:id="@+id/linhaSuperior"
            android:layout_width="2dp"
            android:layout_height="15dp"
            android:background="#2EC4B6" />

        <ImageView
            android:id="@+id/imgDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:src="@drawable/bg_circle_dark"
            app:tint="#2EC4B6" />

        <View
            android:id="@+id/linhaInferior"
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:minHeight="35dp"
            android:background="#2EC4B6" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardConteudoAtalho"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="6dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F8F8F8">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <TextView
                android:id="@+id/txtTituloAtalho"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Consulta"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtHoraAtalho"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="12:00"
                android:textSize="12sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/txtDescricaoAtalho"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/txtTituloAtalho"
                android:layout_marginTop="2dp"
                android:text="Descrição..."
                android:textSize="11sp"
                android:textColor="#888888" />

        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>