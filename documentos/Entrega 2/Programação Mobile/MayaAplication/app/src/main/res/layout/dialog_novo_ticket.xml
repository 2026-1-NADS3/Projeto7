<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Novo Chat"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etTituloTicket"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nome do Assunto (Ex: Dor na lombar)"
        android:padding="12dp"
        android:background="#F0F0F0"
        android:textColorHint="#333333"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/etAssuntoTicket"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:hint="Descreva o problema detalhadamente..."
        android:gravity="top|start"
        android:padding="12dp"
        android:background="#F0F0F0"
        android:textColorHint="#333333"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancelarTicket"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancelar"
            android:backgroundTint="#CCCCCC"
            android:textColor="#000000"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnConcluirTicket"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Concluído"
            android:backgroundTint="#34C7C7"
            android:textColor="#FFFFFF"/>
    </LinearLayout>
</LinearLayout>