<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/itemExercicioRoot"
    android:layout_width="match_parent"
    android:layout_height="90dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    android:background="@drawable/fundo_homepage_sombra"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardIconeExercicio"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="7dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgIconeExercicio"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            app:srcCompat="@drawable/circulo_vermelho" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/txtNomeExercicio"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:text="Nome do Exercício"
        android:textColor="#333333"
        android:textSize="16sp"
        android:layout_marginBottom="6dp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/txtSeriesRepeticoes"
        app:layout_constraintEnd_toStartOf="@+id/imgStatus"
        app:layout_constraintStart_toEndOf="@+id/cardIconeExercicio"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/txtSeriesRepeticoes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="3dp"
        android:text="Séries: 4x"
        android:textColor="#333333"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/imgStatus"
        app:layout_constraintStart_toStartOf="@+id/txtNomeExercicio"
        app:layout_constraintTop_toBottomOf="@+id/txtNomeExercicio" />

    <ImageView
        android:id="@+id/imgStatus"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginBottom="6dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/exercise_circle_incomplete" />

</androidx.constraintlayout.widget.ConstraintLayout>